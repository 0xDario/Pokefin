# Copy to .env.local and fill in real values. Never commit .env.local.
# NEXT_PUBLIC_* values are exposed to the browser — only put public keys here.

# Supabase (anon/publishable key only — never the service-role key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_KEY=your-supabase-anon-key

# Absolute site URL, used for auth redirects (e.g. https://www.pokefin.ca)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Turnstile (public site key)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Sentry — DSN is safe to expose; the auth token is build-only and secret
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
